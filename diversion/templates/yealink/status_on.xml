<?xml version="1.0" encoding="UTF-8"?>
<YealinkIPPhoneImageScreen Beep="no"
>
  <Image
    verticalAlign="middle"
    horizontalAlign="middle"
  >{{ header_logo_url }}</Image>
  <SoftKey index="1">
    <Label>Turn Off</Label>
    <URI>{{ disable_url }}</URI>
  </SoftKey>
  <SoftKey index="2">
    <Label>Modify</Label>
    <URI>{{ enable_url }}</URI>
  </SoftKey>
  <SoftKey index="3">
    <Label>Refresh</Label>
    <URI>{{ refresh_url }}</URI>
  </SoftKey>
  <SoftKey index="4">
    <Label>Exit</Label>
    <URI>Softkey:Exit</URI>
  </SoftKey>
</YealinkIPPhoneImageScreen>